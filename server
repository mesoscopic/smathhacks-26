#!/usr/bin/env python3
import http.server
import socketserver
import urllib.request
import urllib.error

PORT = 8000
NOAA_BASE = "https://www.ndbc.noaa.gov/data/realtime2/"
PROXY_PREFIX = "/noaa/"


class Handler(http.server.SimpleHTTPRequestHandler):
    def do_GET(self):
        if self.path.startswith(PROXY_PREFIX):
            self._proxy_noaa()
        else:
            super().do_GET()

    def _proxy_noaa(self):
        # Strip the local prefix to get the upstream path
        tail = self.path[len(PROXY_PREFIX) :]
        upstream_url = NOAA_BASE + tail

        try:
            with urllib.request.urlopen(upstream_url) as resp:
                body = resp.read()
                self.send_response(resp.status)
                # Forward original headers, skipping hop-by-hop ones
                skip = {"transfer-encoding", "connection"}
                for key, value in resp.headers.items():
                    if key.lower() not in skip:
                        self.send_header(key, value)
                self.send_header("Access-Control-Allow-Origin", "*")
                self.end_headers()
                self.wfile.write(body)

        except urllib.error.HTTPError as e:
            body = e.read()
            self.send_response(e.code)
            self.send_header("Access-Control-Allow-Origin", "*")
            self.send_header("Content-Type", "text/plain")
            self.end_headers()
            self.wfile.write(body)

        except Exception as e:
            self.send_response(502)
            self.send_header("Access-Control-Allow-Origin", "*")
            self.send_header("Content-Type", "text/plain")
            self.end_headers()
            self.wfile.write(f"Proxy error: {e}".encode())


with socketserver.TCPServer(("", PORT), Handler) as httpd:
    httpd.allow_reuse_address = True
    print(f"Serving on http://localhost:{PORT}")
    print(f"NOAA proxy at http://localhost:{PORT}{PROXY_PREFIX}<filename>")
    print("Press Ctrl+C to stop.")
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print("\nServer stopped.")
